#: ../../../reference/contrib/pyopenssl.rst:2
msgid "PyOpenSSL"
msgstr "PyOpenSSL"

#: ../../../reference/contrib/pyopenssl.rst:4
msgid ""
"DEPRECATED: This module is deprecated and will be removed in a future 2.x "
"release. Read more in this `issue <https://github.com/urllib3/urllib3/"
"issues/2680>`_."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:1
msgid ""
"TLS with SNI_-support for Python 2. Follow these instructions if you would "
"like to verify TLS certificates in Python 2. Note, the default libraries do "
"*not* do certificate checking; you need to do additional work to validate "
"certificates yourself."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:6
msgid "This needs the following packages installed:"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:8
msgid "`pyOpenSSL`_ (tested with 16.0.0)"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:9
msgid "`cryptography`_ (minimum 1.3.4, from pyopenssl)"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:10
msgid "`idna`_ (minimum 2.0, from cryptography)"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:12
msgid ""
"However, pyopenssl depends on cryptography, which depends on idna, so while "
"we use all three directly here we end up having relatively few packages "
"required."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:15
msgid "You can install them with the following command:"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:17
msgid "$ python -m pip install pyopenssl cryptography idna"
msgstr "$ python -m pip install pyopenssl cryptography idna"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:21
msgid ""
"To activate certificate checking, call :func:`~urllib3.contrib.pyopenssl."
"inject_into_urllib3` from your Python code before you begin making HTTP "
"requests. This can be done in a ``sitecustomize`` module, or at any other "
"time before your application begins using ``urllib3``, like this:"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:27
msgid ""
"try:\n"
"    import urllib3.contrib.pyopenssl\n"
"    urllib3.contrib.pyopenssl.inject_into_urllib3()\n"
"except ImportError:\n"
"    pass"
msgstr ""
"try:\n"
"    import urllib3.contrib.pyopenssl\n"
"    urllib3.contrib.pyopenssl.inject_into_urllib3()\n"
"except ImportError:\n"
"    pass"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:35
msgid ""
"Now you can use :mod:`urllib3` as you normally would, and it will support "
"SNI when the required modules are installed."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl:38
msgid ""
"Activating this module also has the positive side effect of disabling SSL/"
"TLS compression in Python 2 (see `CRIME attack`_)."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl.extract_from_urllib3:1
msgid "Undo monkey-patching by :func:`inject_into_urllib3`."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/pyopenssl.py:docstring
#: of urllib3.contrib.pyopenssl.inject_into_urllib3:1
msgid "Monkey-patch urllib3 with PyOpenSSL-backed SSL-support."
msgstr ""
