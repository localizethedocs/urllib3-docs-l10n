#: ../../../reference/urllib3.poolmanager.rst:2
msgid "Pool Manager"
msgstr "池管理器"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager:1
msgid ""
"Allows for arbitrary requests while transparently keeping track of necessary "
"connection pools for you."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.connection_from_context:0
#: urllib3.poolmanager.PoolManager.connection_from_host:0
#: urllib3.poolmanager.PoolManager.connection_from_pool_key:0
#: urllib3.poolmanager.PoolManager.connection_from_url:0
#: urllib3.poolmanager.PoolManager.urlopen:0
#: urllib3.poolmanager.ProxyManager.connection_from_host:0
#: urllib3.poolmanager.ProxyManager.urlopen:0
#: ../../../reference/urllib3.poolmanager.rst:0
msgid "Parameters"
msgstr "參數"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager:4
msgid ""
"Number of connection pools to cache before discarding the least recently "
"used pool."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager:8
msgid ""
"Headers to include with all requests, unless other headers are given "
"explicitly."
msgstr "除非明確提供其他標頭，否則所有請求都會包含的標頭。"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager:12
msgid ""
"Additional parameters are used to create fresh :class:`urllib3."
"connectionpool.ConnectionPool` instances."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager:16 urllib3.poolmanager.ProxyManager:32
msgid "Example:"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager:18
msgid ""
"import urllib3\n"
"\n"
"http = urllib3.PoolManager(num_pools=2)\n"
"\n"
"resp1 = http.request(\"GET\", \"https://google.com/\")\n"
"resp2 = http.request(\"GET\", \"https://google.com/mail\")\n"
"resp3 = http.request(\"GET\", \"https://yahoo.com/\")\n"
"\n"
"print(len(http.pools))\n"
"# 2"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.clear:1
msgid "Empty our store of pools and direct them all to close."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.clear:3
msgid ""
"This will not affect in-flight connections, but they will not be re-used "
"after completion."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.clear:0
