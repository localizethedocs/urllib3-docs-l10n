msgstr "回傳值型別"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.connection_from_context:1
msgid ""
"Get a :class:`urllib3.connectionpool.ConnectionPool` based on the request "
"context."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.connection_from_context:3
msgid ""
"``request_context`` must at least contain the ``scheme`` key and its value "
"must be a key in ``key_fn_by_scheme`` instance variable."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.connection_from_host:1
#: urllib3.poolmanager.ProxyManager.connection_from_host:1
msgid ""
"Get a :class:`urllib3.connectionpool.ConnectionPool` based on the host, "
"port, and scheme."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.connection_from_host:3
#: urllib3.poolmanager.ProxyManager.connection_from_host:3
msgid ""
"If ``port`` isn't given, it will be derived from the ``scheme`` using "
"``urllib3.connectionpool.port_by_scheme``. If ``pool_kwargs`` is provided, "
"it is merged with the instance's ``connection_pool_kw`` variable and used to "
"create the new connection pool, if one is needed."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.connection_from_pool_key:1
msgid ""
"Get a :class:`urllib3.connectionpool.ConnectionPool` based on the provided "
"pool key."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.connection_from_pool_key:3
msgid ""
"``pool_key`` should be a namedtuple that only contains immutable objects. At "
"a minimum it must have the ``scheme``, ``host``, and ``port`` fields."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.connection_from_url:1
msgid "Similar to :func:`urllib3.connectionpool.connection_from_url`."
msgstr "與 :func:`urllib3.connectionpool.connection_from_url` 相似。"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.connection_from_url:3
msgid ""
"If ``pool_kwargs`` is not provided and a new pool needs to be constructed, "
"``self.connection_pool_kw`` is used to initialize the :class:`urllib3."
"connectionpool.ConnectionPool`. If ``pool_kwargs`` is provided, it is used "
"instead. Note that if a new pool does not need to be created for the "
"request, the provided ``pool_kwargs`` are not used."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request:1
msgid ""
"Make a request using :meth:`urlopen` with the appropriate encoding of "
"``fields`` based on the ``method`` used."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request:4
msgid ""
"This is a convenience method that requires the least amount of manual "
"effort. It can be used in most situations, while still having the option to "
"drop down to more specific methods when necessary, such as :meth:"
"`request_encode_url`, :meth:`request_encode_body`, or even the lowest level :"
"meth:`urlopen`."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request:10
#: urllib3._request_methods.RequestMethods.request_encode_body:35
#: urllib3._request_methods.RequestMethods.request_encode_url:4
msgid "HTTP request method (such as GET, POST, PUT, etc.)"
msgstr "HTTP 請求方法（例如 GET、POST、PUT 等）"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request:13
#: urllib3._request_methods.RequestMethods.request_encode_body:38
#: urllib3._request_methods.RequestMethods.request_encode_url:7
msgid "The URL to perform the request on."
msgstr "執行請求的 URL。"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request:16
msgid ""
"Data to send in the request body, either :class:`str`, :class:`bytes`, an "
"iterable of :class:`str`/:class:`bytes`, or a file-like object."
msgstr ""
"要發送到請求正文中的資料，可以是 :class:`str`、:class:`bytes`、:class:`str`/:"
"class:`bytes` 的可疊代物件，或是類似檔案的物件。"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request:20
msgid ""
"Data to encode and send in the URL or request body, depending on ``method``."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request:23
#: urllib3._request_methods.RequestMethods.request_encode_body:44
#: urllib3._request_methods.RequestMethods.request_encode_url:13
msgid ""
"Dictionary of custom headers to send, such as User-Agent, If-None-Match, "
"etc. If None, pool headers are used. If provided, these headers completely "
"replace any pool-specific headers."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request:28
msgid ""
"Data to encode and send as JSON with UTF-encoded in the request body. The "
"``\"Content-Type\"`` header will be set to ``\"application/json\"`` unless "
"specified otherwise."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_body:1
msgid ""
"Make a request using :meth:`urlopen` with the ``fields`` encoded in the "
"body. This is useful for request methods like POST, PUT, PATCH, etc."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_body:4
msgid ""
"When ``encode_multipart=True`` (default), then :func:`urllib3."
"encode_multipart_formdata` is used to encode the payload with the "
"appropriate content type. Otherwise :func:`urllib.parse.urlencode` is used "
"with the 'application/x-www-form-urlencoded' content type."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_body:10
msgid ""
"Multipart encoding must be used when posting files, and it's reasonably safe "
"to use it in other times too. However, it may break request signing, such as "
"with OAuth."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_body:14
msgid ""
"Supports an optional ``fields`` parameter of key/value strings AND key/"
"filetuple. A filetuple is a (filename, data, MIME type) tuple where the MIME "
"type is optional. For example::"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_body:18
msgid ""
"fields = {\n"
"    'foo': 'bar',\n"
"    'fakefile': ('foofile.txt', 'contents of foofile'),\n"
"    'realfile': ('barfile.txt', open('realfile').read()),\n"
"    'typedfile': ('bazfile.bin', open('bazfile').read(),\n"
"                  'image/jpeg'),\n"
"    'nonamefile': 'contents of nonamefile field',\n"
"}"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_body:27
msgid ""
"When uploading a file, providing a filename (the first parameter of the "
"tuple) is optional but recommended to best mimic behavior of browsers."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_body:30
msgid ""
"Note that if ``headers`` are supplied, the 'Content-Type' header will be "
"overwritten because it depends on the dynamic random boundary string which "
"is used to compose the body of the request. The random boundary string can "
"be explicitly set with the ``multipart_boundary`` parameter."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_body:41
msgid "Data to encode and send in the request body."
msgstr "要在請求正文中編碼並發送的資料。"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_body:49
msgid ""
"If True, encode the ``fields`` using the multipart/form-data MIME format."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_body:53
msgid ""
"If not specified, then a random boundary will be generated using :func:"
"`urllib3.filepost.choose_boundary`."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_url:1
msgid ""
"Make a request using :meth:`urlopen` with the ``fields`` encoded in the url. "
"This is useful for request methods like GET, HEAD, DELETE, etc."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3._request_methods.RequestMethods.request_encode_url:10
msgid "Data to encode and send in the URL."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.urlopen:1
msgid ""
"Same as :meth:`urllib3.HTTPConnectionPool.urlopen` with custom cross-host "
"redirect logic and only sends the request-uri portion of the ``url``."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.PoolManager.urlopen:5
msgid ""
"The given ``url`` parameter must be absolute, such that an appropriate :"
"class:`urllib3.connectionpool.ConnectionPool` can be chosen for it."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.ProxyManager:1
msgid ""
"Behaves just like :class:`PoolManager`, but sends all requests through the "
"defined proxy, using the CONNECT method for HTTPS URLs."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.ProxyManager:4
msgid "The URL of the proxy to be used."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.ProxyManager:7
msgid ""
"A dictionary containing headers that will be sent to the proxy. In case of "
"HTTP they are being sent with each request, while in the HTTPS/CONNECT case "
"they are sent only once. Could be used for proxy authentication."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.ProxyManager:13
msgid ""
"The proxy SSL context is used to establish the TLS connection to the proxy "
"when using HTTPS proxies."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.ProxyManager:17
msgid ""
"(Defaults to False) If set to True will forward requests to the HTTPS proxy "
"to be made on behalf of the client instead of creating a TLS tunnel via the "
"CONNECT method. **Enabling this flag means that request and response headers "
"and content will be visible from the HTTPS proxy** whereas tunneling keeps "
"request and response headers and content private.  IP address, target "
"hostname, SNI, and port are always visible to an HTTPS proxy even when this "
"flag is disabled."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.ProxyManager:26
msgid "The hostname of the certificate to verify against."
msgstr "用於驗證的證書主機名稱。"

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.ProxyManager:29
msgid "The fingerprint of the certificate to verify against."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.ProxyManager:34
msgid ""
"import urllib3\n"
"\n"
"proxy = urllib3.ProxyManager(\"https://localhost:3128/\")\n"
"\n"
"resp1 = proxy.request(\"GET\", \"http://google.com/\")\n"
"resp2 = proxy.request(\"GET\", \"http://httpbin.org/\")\n"
"\n"
"# One pool was shared by both plain HTTP requests.\n"
"print(len(proxy.pools))\n"
"# 1\n"
"\n"
"resp3 = proxy.request(\"GET\", \"https://httpbin.org/\")\n"
"resp4 = proxy.request(\"GET\", \"https://twitter.com/\")\n"
"\n"
"# A separate pool was added for each HTTPS target.\n"
"print(len(proxy.pools))\n"
"# 3"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/poolmanager.py:docstring
#: of urllib3.poolmanager.ProxyManager.urlopen:1
msgid "Same as HTTP(S)ConnectionPool.urlopen, ``url`` must be absolute."
msgstr ""

