#: ../../../reference/contrib/appengine.rst:2
msgid "Google App Engine"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine:1
msgid ""
"This module provides a pool manager that uses Google App Engine's `URLFetch "
"Service <https://cloud.google.com/appengine/docs/python/urlfetch>`_."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine:4
msgid "Example usage::"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine:6
msgid ""
"from urllib3 import PoolManager\n"
"from urllib3.contrib.appengine import AppEngineManager, "
"is_appengine_sandbox\n"
"\n"
"if is_appengine_sandbox():\n"
"    # AppEngineManager uses AppEngine's URLFetch API behind the scenes\n"
"    http = AppEngineManager()\n"
"else:\n"
"    # PoolManager uses a socket-level API behind the scenes\n"
"    http = PoolManager()\n"
"\n"
"r = http.request('GET', 'https://google.com/')"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine:18
msgid ""
"There are `limitations <https://cloud.google.com/appengine/docs/python/"
"urlfetch/#Python_Quotas_and_limits>`_ to the URLFetch service and it may not "
"be the best choice for your application. There are three options for using "
"urllib3 on Google App Engine:"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine:22
msgid ""
"You can use :class:`AppEngineManager` with URLFetch. URLFetch is cost-"
"effective in many circumstances as long as your usage is within the "
"limitations."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine:25
msgid ""
"You can use a normal :class:`~urllib3.PoolManager` by enabling sockets. "
"Sockets also have `limitations and restrictions <https://cloud.google.com/"
"appengine/docs/python/sockets/   #limitations-and-restrictions>`_ and have a "
"lower free quota than URLFetch. To use sockets, be sure to specify the "
"following in your ``app.yaml``::"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine:30
msgid ""
"env_variables:\n"
"    GAE_USE_SOCKETS_HTTPLIB : 'true'"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine:33
msgid ""
"3. If you are using `App Engine Flexible <https://cloud.google.com/appengine/"
"docs/flexible/>`_, you can use the standard :class:`PoolManager` without any "
"configuration or special environment variables."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine.AppEngineManager:1
msgid "Connection manager for Google App Engine sandbox applications."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine.AppEngineManager:3
msgid ""
"This manager uses the URLFetch service directly instead of using the "
"emulated httplib, and is subject to URLFetch limitations as described in the "
"App Engine documentation `here <https://cloud.google.com/appengine/docs/"
"python/urlfetch>`_."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine.AppEngineManager:8
msgid "Notably it will raise an :class:`AppEnginePlatformError` if:"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine.AppEngineManager:9
msgid "URLFetch is not available."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine.AppEngineManager:10
msgid ""
"If you attempt to use this on App Engine Flexible, as full socket support is "
"available."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine.AppEngineManager:12
msgid "If a request size is more than 10 megabytes."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine.AppEngineManager:13
msgid "If a response size is more than 32 megabytes."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine.AppEngineManager:14
msgid "If you use an unsupported request method such as OPTIONS."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/contrib/appengine.py:docstring
#: of urllib3.contrib.appengine.AppEngineManager:16
msgid "Beyond those cases, it will raise normal urllib3 errors."
msgstr ""
