#: ../../../reference/contrib/pyopenssl.rst:2
msgid "PyOpenSSL"
msgstr "PyOpenSSL"

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl:1
msgid ""
"Module for using pyOpenSSL as a TLS backend. This module was relevant before "
"the standard library ``ssl`` module supported SNI, but now that we've "
"dropped support for Python 2.7 all relevant Python versions support SNI so "
"**this module is no longer recommended**."
msgstr ""

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl:6
msgid "This needs the following packages installed:"
msgstr ""

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl:8
msgid "`pyOpenSSL`_ (tested with 19.0.0)"
msgstr ""

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl:9
msgid "`cryptography`_ (minimum 2.3, from pyopenssl)"
msgstr ""

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl:10
msgid "`idna`_ (minimum 2.1, from cryptography)"
msgstr ""

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl:12
msgid ""
"However, pyOpenSSL depends on cryptography, so while we use all three "
"directly here we end up having relatively few packages required."
msgstr ""

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl:15
msgid "You can install them with the following command:"
msgstr "您可以使用以下命令安裝它們："

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl:17
msgid "$ python -m pip install pyopenssl cryptography idna"
msgstr "$ python -m pip install pyopenssl cryptography idna"

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl:21
msgid ""
"To activate certificate checking, call :func:`~urllib3.contrib.pyopenssl."
"inject_into_urllib3` from your Python code before you begin making HTTP "
"requests. This can be done in a ``sitecustomize`` module, or at any other "
"time before your application begins using ``urllib3``, like this:"
msgstr ""

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl:27
msgid ""
"try:\n"
"    import urllib3.contrib.pyopenssl\n"
"    urllib3.contrib.pyopenssl.inject_into_urllib3()\n"
"except ImportError:\n"
"    pass"
msgstr ""
"try:\n"
"    import urllib3.contrib.pyopenssl\n"
"    urllib3.contrib.pyopenssl.inject_into_urllib3()\n"
"except ImportError:\n"
"    pass"

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl.extract_from_urllib3:1
msgid "Undo monkey-patching by :func:`inject_into_urllib3`."
msgstr ""

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl.extract_from_urllib3:0
#: urllib3.contrib.pyopenssl.inject_into_urllib3:0
msgid "Return type"
msgstr "回傳值型別"

#: ../../../../src/urllib3/contrib/pyopenssl.py:docstring of
#: urllib3.contrib.pyopenssl.inject_into_urllib3:1
msgid "Monkey-patch urllib3 with PyOpenSSL-backed SSL-support."
msgstr ""
