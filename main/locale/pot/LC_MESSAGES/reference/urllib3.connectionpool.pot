msgid "Parameters"
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool:3
msgid ""
"Host used for this HTTP Connection (e.g. \"localhost\"), passed into :class:"
"`http.client.HTTPConnection`."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool:7
msgid ""
"Port used for this HTTP Connection (None is equivalent to 80), passed into :"
"class:`http.client.HTTPConnection`."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool:11
msgid ""
"Socket timeout in seconds for each individual connection. This can be a "
"float or integer, which sets the timeout for the HTTP request, or an "
"instance of :class:`urllib3.util.Timeout` which gives you more fine-grained "
"control over request timeouts. After the constructor has been parsed, this "
"is always a `urllib3.util.Timeout` object."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool:18
msgid ""
"Number of connections to save that can be reused. More than 1 is useful in "
"multithreaded situations. If ``block`` is set to False, more connections "
"will be created but they will not be saved once they've been used."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool:24
msgid ""
"If set to True, no more than ``maxsize`` connections will be used at a time. "
"When no free connections are available, the call will block until a "
"connection has been released. This is a useful side effect for particular "
"multithreaded situations where one does not want to use more than maxsize "
"connections per host to prevent flooding."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool:31
msgid ""
"Headers to include with all requests, unless other headers are given "
"explicitly."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool:35
msgid "Retry configuration to use by default with requests in this pool."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool:38
msgid ""
"Parsed proxy URL, should not be used directly, instead, see :class:`urllib3."
"ProxyManager`"
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool:42
msgid ""
"A dictionary with proxy headers, should not be used directly, instead, see :"
"class:`urllib3.ProxyManager`"
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool:46
msgid ""
"Additional parameters are used to create fresh :class:`urllib3.connection."
"HTTPConnection`, :class:`urllib3.connection.HTTPSConnection` instances."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.ConnectionPool.close:1
#: urllib3.connectionpool.HTTPConnectionPool.close:1
msgid "Close all pooled connections and disable the pool."
msgstr ""

#: ../../../reference/urllib3.connectionpool.rst:0
#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.ConnectionPool.close:0
#: urllib3.connectionpool.HTTPConnectionPool.close:0
#: urllib3.connectionpool.HTTPConnectionPool.is_same_host:0
#: urllib3.connectionpool.connection_from_url:0
msgid "Return type"
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.is_same_host:1
msgid ""
"Check if the given ``url`` is a member of the same host as this connection "
"pool."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:1
msgid ""
"Get a connection from the pool and perform an HTTP request. This is the "
"lowest level call for making a request, so you'll need to specify all the "
"raw details."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:7
msgid ""
"More commonly, it's appropriate to use a convenience method such as :meth:"
"`request`."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:12
msgid ""
"`release_conn` will only behave as expected if `preload_content=False` "
"because we want to make `preload_content=False` the default behaviour "
"someday soon without breaking backwards compatibility."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:17
msgid "HTTP request method (such as GET, POST, PUT, etc.)"
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:20
msgid "The URL to perform the request on."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:23
msgid ""
"Data to send in the request body, either :class:`str`, :class:`bytes`, an "
"iterable of :class:`str`/:class:`bytes`, or a file-like object."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:27
msgid ""
"Dictionary of custom headers to send, such as User-Agent, If-None-Match, "
"etc. If None, pool headers are used. If provided, these headers completely "
"replace any pool-specific headers."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:32
msgid ""
"Configure the number of retries to allow before raising a :class:`~urllib3."
"exceptions.MaxRetryError` exception.  If ``None`` (default) will retry 3 "
"times, see ``Retry.DEFAULT``. Pass a :class:`~urllib3.util.retry.Retry` "
"object for fine-grained control over different types of retries. Pass an "
"integer number to retry connection errors that many times, but no other "
"types of errors. Pass zero to never retry.  If ``False``, then retries are "
"disabled and any exception is raised immediately. Also, instead of raising a "
"MaxRetryError on redirects, the redirect response will be returned."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:33
msgid ""
"Configure the number of retries to allow before raising a :class:`~urllib3."
"exceptions.MaxRetryError` exception."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:36
msgid ""
"If ``None`` (default) will retry 3 times, see ``Retry.DEFAULT``. Pass a :"
"class:`~urllib3.util.retry.Retry` object for fine-grained control over "
"different types of retries. Pass an integer number to retry connection "
"errors that many times, but no other types of errors. Pass zero to never "
"retry."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:42
msgid ""
"If ``False``, then retries are disabled and any exception is raised "
"immediately. Also, instead of raising a MaxRetryError on redirects, the "
"redirect response will be returned."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:48
msgid ""
"If True, automatically handle redirects (status codes 301, 302, 303, 307, "
"308). Each redirect counts as a retry. Disabling retries will disable "
"redirect, too."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:53
msgid ""
"If ``True``, will make sure that the host of the pool requests is consistent "
"else will raise HostChangedError. When ``False``, you can use the pool on an "
"HTTP proxy and request foreign hosts."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:58
msgid ""
"If specified, overrides the default timeout for this one request. It may be "
"a float (in seconds) or an instance of :class:`urllib3.util.Timeout`."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:63
msgid ""
"If set and the pool is set to block=True, then this method will block for "
"``pool_timeout`` seconds and raise EmptyPoolError if no connection is "
"available within the time period."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:68
msgid "If True, the response's body will be preloaded into memory."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:71
msgid ""
"If True, will attempt to decode the body based on the 'content-encoding' "
"header."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:75
msgid ""
"If False, then the urlopen call will not release the connection back into "
"the pool once a response is received (but will release if you read the "
"entire contents of the response such as when `preload_content=True`). This "
"is useful if you're not preloading the response's content immediately. You "
"will need to call ``r.release_conn()`` on the response ``r`` to return the "
"connection back into the pool. If None, it takes the value of "
"``preload_content`` which defaults to ``True``."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:85
msgid ""
"If True, urllib3 will send the body using chunked transfer encoding. "
"Otherwise, urllib3 will send the body using the standard content-length "
"form. Defaults to False."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPConnectionPool.urlopen:90
msgid ""
"Position to seek to in file-like body in the event of a retry or redirect. "
"Typically this won't need to be set because urllib3 will auto-populate the "
"value when needed."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPSConnectionPool:1
msgid "Bases: :py:class:`~urllib3.connectionpool.HTTPConnectionPool`"
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPSConnectionPool:1
msgid "Same as :class:`.HTTPConnectionPool`, but HTTPS."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPSConnectionPool:3
msgid ""
":class:`.HTTPSConnection` uses one of ``assert_fingerprint``, "
"``assert_hostname`` and ``host`` in this order to verify connections. If "
"``assert_hostname`` is False, no verification is done."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.HTTPSConnectionPool:7
msgid ""
"The ``key_file``, ``cert_file``, ``cert_reqs``, ``ca_certs``, "
"``ca_cert_dir``, ``ssl_version``, ``key_password`` are only used if :mod:"
"`ssl` is available and are fed into :meth:`urllib3.util.ssl_wrap_socket` to "
"upgrade the connection socket into an SSL socket."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.ConnectionPool:1
msgid "Bases: :py:class:`object`"
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.ConnectionPool:1
msgid ""
"Base class for all connection pools, such as :class:`.HTTPConnectionPool` "
"and :class:`.HTTPSConnectionPool`."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.ConnectionPool:5
msgid ""
"ConnectionPool.urlopen() does not normalize or percent-encode target URIs "
"which is useful if your target server doesn't support percent-encoded target "
"URIs."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.connection_from_url:1
msgid "Given a url, return an :class:`.ConnectionPool` instance of its host."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.connection_from_url:3
msgid ""
"This is a shortcut for not having to parse out the scheme, host, and port of "
"the url before creating an :class:`.ConnectionPool` instance."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.connection_from_url:6
msgid "Absolute URL string that must include the scheme. Port is optional."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.connection_from_url:9
msgid ""
"Passes additional parameters to the constructor of the appropriate :class:`."
"ConnectionPool`. Useful for specifying things like timeout, maxsize, "
"headers, etc."
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.connection_from_url:14
msgid "Example::"
msgstr ""

#: ../../../../src/urllib3/connectionpool.py:docstring of
#: urllib3.connectionpool.connection_from_url:16
msgid ""
">>> conn = connection_from_url('http://google.com/')\n"
">>> r = conn.request('GET', '/')"
msgstr ""
