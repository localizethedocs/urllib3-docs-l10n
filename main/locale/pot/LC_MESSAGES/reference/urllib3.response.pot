#: urllib3.response.HTTPResponse:1
msgid "HTTP Response container."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse:3
msgid ""
"Backwards-compatible with :class:`http.client.HTTPResponse` but the response "
"``body`` is loaded and decoded on-demand when the ``data`` property is "
"accessed.  This class is also compatible with the Python standard library's :"
"mod:`io` module, and can hence be treated as a readable object in the "
"context of that framework."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse:9
msgid ""
"Extra parameters for behaviour not present in :class:`http.client."
"HTTPResponse`:"
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse:11
msgid "If True, the response's body will be preloaded during construction."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse:14 urllib3.response.HTTPResponse.read:9
#: urllib3.response.HTTPResponse.read1:8
#: urllib3.response.HTTPResponse.read_chunked:9
#: urllib3.response.HTTPResponse.stream:11
msgid ""
"If True, will attempt to decode the body based on the 'content-encoding' "
"header."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse:18
msgid ""
"When this HTTPResponse wrapper is generated from an :class:`http.client."
"HTTPResponse` object, it's convenient to include the original for debug "
"purposes. It's otherwise unused."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse:23
msgid ""
"The retries contains the last :class:`~urllib3.util.retry.Retry` that was "
"used during the request."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse:27
msgid ""
"Enforce content length checking. Body returned by server must match value of "
"Content-Length header, if present. Otherwise, raise error."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.drain_conn:1
msgid ""
"Read and discard any remaining HTTP response data in the response connection."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.drain_conn:3
msgid ""
"Unread data in the HTTPResponse connection blocks the connection from being "
"released back to the pool."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.fileno:1
msgid "Return underlying file descriptor if one exists."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.fileno:3
msgid "Raise OSError if the IO object does not use a file descriptor."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.flush:1
msgid "Flush write buffers, if applicable."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.flush:3
msgid "This is not implemented for read-only and non-blocking streams."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.isatty:1
msgid "Return whether this is an 'interactive' stream."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.isatty:3
msgid "Return False if it can't be determined."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.read:1
msgid ""
"Similar to :meth:`http.client.HTTPResponse.read`, but with two additional "
"parameters: ``decode_content`` and ``cache_content``."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.read:4
#: urllib3.response.HTTPResponse.read_chunked:4
msgid ""
"How much of the content to read. If specified, caching is skipped because it "
"doesn't make sense to cache partial content as the full response."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.read:13
msgid ""
"If True, will save the returned data such that the same result is returned "
"despite of the state of the underlying file object. This is useful if you "
"want the ``.data`` property to continue working after having ``.read()`` the "
"file object. (Overridden if ``amt`` is set.)"
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.read1:1
msgid ""
"Similar to ``http.client.HTTPResponse.read1`` and documented in :meth:`io."
"BufferedReader.read1`, but with an additional parameter: ``decode_content``."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.read1:5
msgid "How much of the content to read."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.read_chunked:1
msgid ""
"Similar to :meth:`HTTPResponse.read`, but with an additional parameter: "
"``decode_content``."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.readable:1
msgid "Return whether object was opened for reading."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.readable:3
msgid "If False, read() will raise OSError."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.readline:1
msgid "Read and return a line from the stream."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.readline:3
msgid "If size is specified, at most size bytes will be read."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.readline:5
msgid ""
"The line terminator is always b'\\n' for binary files; for text files, the "
"newlines argument to open can be used to select the line terminator(s) "
"recognized."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.readlines:1
msgid "Return a list of lines from the stream."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.readlines:3
msgid ""
"hint can be specified to control the number of lines read: no more lines "
"will be read if the total size (in bytes/characters) of all lines so far "
"exceeds hint."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seek:1
msgid "Change the stream position to the given byte offset."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seek:3
msgid "offset"
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seek:4
msgid "The stream position, relative to 'whence'."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seek:5
msgid "whence"
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seek:6
msgid "The relative position to seek from."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seek:8
msgid ""
"The offset is interpreted relative to the position indicated by whence. "
"Values for whence are:"
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seek:11
msgid ""
"os.SEEK_SET or 0 -- start of stream (the default); offset should be zero or "
"positive"
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seek:12
msgid "os.SEEK_CUR or 1 -- current stream position; offset may be negative"
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seek:13
msgid "os.SEEK_END or 2 -- end of stream; offset is usually negative"
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seek:15
msgid "Return the new absolute position."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seekable:1
msgid "Return whether object supports random access."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.seekable:3
msgid ""
"If False, seek(), tell() and truncate() will raise OSError. This method may "
"need to do a test seek()."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.stream:1
msgid ""
"A generator wrapper for the read() method. A call will block until ``amt`` "
"bytes have been read from the connection or until the connection is closed."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.stream:5
msgid ""
"How much of the content to read. The generator will return up to much data "
"per iteration, but may return less. This is particularly likely when using "
"compressed data. However, the empty string will never be returned."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.supports_chunked_reads:1
msgid ""
"Checks if the underlying file-like object looks like a :class:`http.client."
"HTTPResponse` object. We do this by testing for the fp attribute. If it is "
"present we assume it returns raw chunks as processed by read_chunked()."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.tell:1
msgid ""
"Obtain the number of bytes pulled over the wire so far. May differ from the "
"amount of content returned by :meth:`HTTPResponse.read` if bytes are encoded "
"on the wire (e.g, compressed)."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.truncate:1
msgid "Truncate file to size bytes."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.truncate:3
msgid ""
"File pointer is left unchanged. Size defaults to the current IO position as "
"reported by tell(). Return the new size."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.url:1
msgid ""
"Returns the URL that was the source of this response. If the request that "
"generated this response redirected, this method will return the final "
"redirect location."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.writable:1
msgid "Return whether object was opened for writing."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.writable:3
msgid "If False, write() will raise OSError."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.writelines:1
msgid "Write a list of lines to stream."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.HTTPResponse.writelines:3
msgid ""
"Line separators are not added, so it is usual for each of the lines provided "
"to have a line separator at the end."
msgstr ""

#: ../../../reference/urllib3.response.rst:23
msgid "Decoders"
msgstr ""

#: ../../../reference/urllib3.response.rst:25
msgid ""
"Decoder classes are used for transforming compressed HTTP bodies using the "
"``Content-Encoding`` into their uncompressed binary representation."
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.MultiDecoder:1
msgid "From RFC7231:"
msgstr ""

#: ../../../../src/urllib3/response.py:docstring of
#: urllib3.response.MultiDecoder:2
msgid ""
"If one or more encodings have been applied to a representation, the sender "
"that applied the encodings MUST generate a Content-Encoding header field "
"that lists the content codings in the order in which they were applied."
msgstr ""
