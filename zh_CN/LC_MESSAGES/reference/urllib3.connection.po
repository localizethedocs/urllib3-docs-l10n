msgid ""
"Disable Nagle's algorithm by default. ``[(socket.IPPROTO_TCP, socket."
"TCP_NODELAY, 1)]``"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.getresponse:1
msgid "Get the response from the server."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.getresponse:3
msgid ""
"If the HTTPConnection is in the correct state, returns an instance of "
"HTTPResponse or of whatever object is returned by the response_class "
"variable."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.getresponse:5
msgid ""
"If a request has not been sent or if a previous response has not be handled, "
"ResponseNotReady is raised. If the HTTP response indicates that the "
"connection should be closed, then it will be closed before the response is "
"returned. When the connection is closed, the underlying socket is closed."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.host:1
msgid ""
"Getter method to remove any trailing dots that indicate the hostname is an "
"FQDN."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.host:3
msgid ""
"In general, SSL certificates don't include the trailing dot indicating a "
"fully-qualified domain name, and thus, they don't validate properly when "
"checked against a domain name that includes the dot. In addition, some "
"servers may not expect to receive the trailing dot when provided."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.host:8
msgid ""
"However, the hostname with trailing dot is critical to DNS resolution; doing "
"a lookup with the trailing dot will properly only resolve the appropriate "
"FQDN, whereas a lookup without a trailing dot will search the system's "
"search domain list. Thus, it's important to keep the original host around "
"for use only in those cases where it's appropriate (i.e., when doing DNS "
"lookup to establish the actual TCP connection across which we're going to "
"send HTTP requests)."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.is_verified:1
msgid "Whether this connection verifies the host's certificate."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.proxy_is_forwarding:1
msgid "Return True if a forwarding proxy is configured, else return False"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.proxy_is_tunneling:1
msgid "Return True if a tunneling proxy is configured, else return False"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.request:1
msgid "Send a complete request to the server."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.request_chunked:1
msgid ""
"Alternative to the common request method, which sends the body with chunked "
"encoding and not as one block"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.set_tunnel:1
msgid "Set up host and port for HTTP CONNECT tunnelling."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.set_tunnel:3
msgid ""
"In a connection that uses HTTP CONNECT tunnelling, the host passed to the "
"constructor is used as a proxy server that relays all communication to the "
"endpoint passed to `set_tunnel`. This done by sending an HTTP CONNECT "
"request to the proxy server when the connection is established."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.set_tunnel:8
msgid ""
"This method must be called before the HTTP connection has been established."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.set_tunnel:11
msgid ""
"The headers argument should be a mapping of extra HTTP headers to send with "
"the CONNECT request."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection.set_tunnel:14
msgid ""
"As HTTP/1.1 is used for HTTP CONNECT tunnelling request, as per the RFC "
"(https://tools.ietf.org/html/rfc7231#section-4.3.6), a HTTP Host: header "
"must be provided, matching the authority-form of the request target provided "
"as the destination for the CONNECT request. If a HTTP Host: header is not "
"provided via the headers argument, one is generated and transmitted "
"automatically."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPSConnection:1
msgid ""
"Many of the parameters to this constructor are passed to the underlying SSL "
"socket by means of :py:func:`urllib3.util.ssl_wrap_socket`."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPSConnection.set_cert:1
msgid "This method should only be called once, before the connection is used."
msgstr ""

