#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection:1
msgid ""
"Based on :class:`http.client.HTTPConnection` but provides an extra "
"constructor backwards-compatibility layer between older and newer Pythons."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection:4
msgid ""
"Additional keyword parameters are used to configure attributes of the "
"connection. Accepted parameters include:"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection:7
msgid "``source_address``: Set the source address for the current connection."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection:8
msgid ""
"``socket_options``: Set specific options on the underlying socket. If not "
"specified, then defaults are loaded from ``HTTPConnection."
"default_socket_options`` which includes disabling Nagle's algorithm (sets "
"TCP_NODELAY to 1) unless the connection is behind a proxy."
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection:12
msgid ""
"For example, if you wish to enable TCP Keep Alive in addition to the "
"defaults, you might pass:"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection:15
msgid ""
"HTTPConnection.default_socket_options + [\n"
"    (socket.SOL_SOCKET, socket.SO_KEEPALIVE, 1),\n"
"]"
msgstr ""

#: ../../../../../../.conda/lib/python3.13/site-packages/urllib3/connection.py:docstring
#: of urllib3.connection.HTTPConnection:21
msgid ""
"Or you may want to disable the defaults by passing an empty list (e.g., "
"``[]``)."
msgstr ""

