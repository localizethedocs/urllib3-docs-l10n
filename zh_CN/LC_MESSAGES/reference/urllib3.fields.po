"'foo': 'bar',\n"
"'fakefile': ('foofile.txt', 'contents of foofile'),\n"
"'realfile': ('barfile.txt', open('realfile').read()),\n"
"'typedfile': ('bazfile.bin', open('bazfile').read(), 'image/jpeg'),\n"
"'nonamefile': 'contents of nonamefile field',"
msgstr ""

